# Nombre de la marca mostrado en el encabezado y el título del sitio
NEXT_PUBLIC_APP_NAME=Grupo Banzai Veracruz

# Admin credentials (obligatorias — sin estas no se puede iniciar sesión)
ADMIN_EMAIL=admin@tudominio.com
ADMIN_PASSWORD=cambia-esta-contrasena

# AI provider (OpenAI)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini

# WhatsApp Business API (Phase 2 — optional)
WHATSAPP_VERIFY_TOKEN=your_verify_token_here
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here
WHATSAPP_ACCESS_TOKEN=your_access_token_here
